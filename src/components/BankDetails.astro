---
const rows = [
  { label: 'Account Name', value: 'LAHSIV FOUNDATION', copy: false },
  { label: 'Bank', value: 'HDFC Bank', copy: false },
  { label: 'Branch', value: 'Junglighat, Port Blair', copy: false },
  { label: 'Account Number', value: '50200096458732', copy: true },
  { label: 'IFSC Code', value: 'HDFC0001994', copy: true },
];
---

<div class="relative overflow-hidden bg-white rounded-2xl border border-ash shadow-sm max-w-2xl">
  <!-- Coral top stripe -->
  <div aria-hidden="true" class="h-1 bg-gradient-to-r from-coral via-coral to-coral/60"></div>

  <div class="p-8 md:p-10">
    <!-- Header -->
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <p class="text-coral text-xs font-semibold tracking-[0.28em] uppercase flex items-center gap-3 mb-3">
          <span aria-hidden="true" class="block w-5 h-px bg-coral"></span>
          Bank transfer
        </p>
        <h3 class="font-serif text-2xl md:text-3xl text-teal leading-tight">
          Direct bank transfer
        </h3>
      </div>
      <!-- 80G chip -->
      <span class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-forest/10 border border-forest/30 text-forest text-xs font-semibold tracking-wide">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
        80G · Tax exempt
      </span>
    </div>

    <!-- Details -->
    <dl class="divide-y divide-ash">
      {rows.map((row) => (
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4 gap-2">
          <dt class="text-xs tracking-[0.18em] uppercase text-stone font-semibold">{row.label}</dt>
          <dd class="flex items-center gap-3 sm:justify-end">
            <span class={`text-ink text-lg md:text-xl font-medium sm:text-right break-all ${row.copy ? 'font-mono tracking-wide' : 'font-sans tracking-tight'}`}>
              {row.value}
            </span>
            {row.copy && (
              <button
                type="button"
                class="copy-btn shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-ash text-stone hover:border-coral hover:text-coral hover:bg-coral/5 transition-all duration-200 text-xs font-medium"
                data-copy-value={row.value}
                aria-label={`Copy ${row.label}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <span class="copy-label">Copy</span>
              </button>
            )}
          </dd>
        </div>
      ))}
    </dl>

    <!-- 80G note -->
    <div class="mt-8 p-5 rounded-xl bg-sand/40 border border-sand">
      <p class="text-sm text-ink/85 leading-relaxed">
        <strong class="text-teal font-semibold">For 80G receipts:</strong> email a screenshot of your transfer along with your PAN and postal address to
        <a href="mailto:lahsivfoundation@gmail.com" class="text-coral font-medium border-b border-coral/50 hover:border-coral transition-colors">lahsivfoundation@gmail.com</a>.
      </p>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const val = btn.dataset.copyValue || '';
      const label = btn.querySelector<HTMLSpanElement>('.copy-label');
      try {
        await navigator.clipboard.writeText(val);
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied!';
          btn.classList.add('text-forest', 'border-forest/60', 'bg-forest/5');
          btn.classList.remove('hover:text-coral', 'hover:border-coral', 'hover:bg-coral/5');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('text-forest', 'border-forest/60', 'bg-forest/5');
            btn.classList.add('hover:text-coral', 'hover:border-coral', 'hover:bg-coral/5');
          }, 1800);
        }
      } catch {
        if (label) label.textContent = 'Copy failed';
      }
    });
  });
</script>
