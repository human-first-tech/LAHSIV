---
interface CTA {
  label: string;
  href: string;
}

interface Props {
  headline: string;
  subheadline: string;
  primaryCTA?: CTA;
  secondaryCTA?: CTA;
  eyebrow?: string;
}

const {
  headline,
  subheadline,
  primaryCTA,
  secondaryCTA,
  eyebrow = 'Foundation · Andaman & Nicobar',
} = Astro.props;
---

<section class="relative overflow-hidden bg-teal text-sand">
  <!-- Decorative color blobs -->
  <div
    aria-hidden="true"
    class="absolute -top-20 -left-16 w-96 h-96 rounded-full bg-coral/15 blur-3xl pointer-events-none"
  ></div>
  <div
    aria-hidden="true"
    class="absolute -bottom-24 -right-10 w-[32rem] h-[32rem] rounded-full bg-sand/10 blur-3xl pointer-events-none"
  ></div>
  <!-- Subtle dot pattern -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: radial-gradient(circle at 1px 1px, #FFF3B0 1px, transparent 0); background-size: 32px 32px;"
  ></div>

  <div class="relative container-page py-16 md:py-20 lg:py-24">
    <div class="max-w-4xl">
      <!-- Coral accent rule (above) -->
      <div aria-hidden="true" class="w-16 h-[3px] bg-coral mb-7"></div>

      <!-- Wordmark -->
      <h1 class="font-serif font-semibold text-6xl md:text-7xl lg:text-[7rem] leading-none text-sand tracking-tight">
        {headline}
      </h1>

      <!-- Eyebrow (below brand) -->
      <div class="mt-6 flex items-center gap-3">
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-coral"></span>
        <span class="text-coral text-xs font-semibold tracking-[0.28em] uppercase">{eyebrow}</span>
      </div>

      <!-- Tagline -->
      <p class="mt-6 max-w-2xl font-serif italic text-lg md:text-xl text-sand/95 leading-[1.4]">
        {subheadline}
      </p>

      <!-- CTAs -->
      {(primaryCTA || secondaryCTA) && (
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          {primaryCTA && (
            <a
              href={primaryCTA.href}
              class="btn-coral text-base px-8 py-4 shadow-lg shadow-black/25 inline-flex items-center gap-2 group w-fit"
            >
              {primaryCTA.label}
              <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </a>
          )}
          {secondaryCTA && (
            <a
              href={secondaryCTA.href}
              class="btn border-2 border-sand/80 text-sand bg-transparent hover:bg-sand hover:text-teal hover:-translate-y-0.5 px-8 py-4 w-fit"
            >
              {secondaryCTA.label}
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Wave divider into next section -->
  <svg
    aria-hidden="true"
    class="absolute bottom-0 left-0 w-full h-12 md:h-16 text-white"
    viewBox="0 0 1440 80"
    preserveAspectRatio="none"
  >
    <path
      d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
      fill="currentColor"
    />
  </svg>
</section>
