---
interface Props {
  title: string;
  body: string;
  number?: string;
}

const { title, body, number } = Astro.props;
---

<article class="group relative bg-white border border-ash rounded-2xl p-8 md:p-10 transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1 hover:border-coral/40 h-full flex flex-col">
  <!-- Coral accent stripe -->
  <div
    aria-hidden="true"
    class="absolute top-0 left-8 md:left-10 right-8 md:right-10 h-[2px] bg-coral/40 group-hover:bg-coral transition-colors duration-300"
  ></div>

  {number && (
    <p class="text-coral text-xs font-semibold tracking-[0.28em] uppercase flex items-center gap-3 mb-5">
      <span aria-hidden="true" class="block w-5 h-px bg-coral"></span>
      {number}
    </p>
  )}

  <h3 class="font-serif text-2xl md:text-3xl text-teal leading-tight">{title}</h3>
  <p class="mt-4 text-ink/85 leading-relaxed">{body}</p>
</article>
