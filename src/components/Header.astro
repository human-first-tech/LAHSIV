---
interface Props {
  activeRoute?: string;
}

const { activeRoute = '/' } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Our Work', href: '/work' },
  { label: 'Impact Stories', href: '/impact-stories' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
];

const isActive = (href: string) => {
  if (href === '/') return activeRoute === '/';
  return activeRoute.startsWith(href);
};
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-ash">
  <div class="container-page flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-3" aria-label="Lahsiv Foundation home">
      <img
        src="/images/logo.png"
        alt="Lahsiv Foundation"
        class="h-12 w-auto"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <span
        class="hidden items-center justify-center h-12 w-12 rounded-lg bg-teal text-white font-serif font-semibold text-lg"
        aria-hidden="true"
      >L</span>
      <span class="font-serif font-semibold text-teal text-xl hidden sm:inline">Lahsiv Foundation</span>
    </a>

    <nav class="hidden lg:block" aria-label="Primary navigation">
      <ul class="flex items-center gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'text-coral'
                  : 'text-ink hover:text-teal',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/contact#donate" class="hidden lg:inline-flex btn-coral text-sm px-5 py-2.5">
      Donate
    </a>

    <button
      id="mobile-menu-toggle"
      class="lg:hidden p-2 text-ink hover:text-teal"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-ash bg-white"
    aria-label="Mobile navigation"
  >
    <ul class="container-page py-4 flex flex-col gap-1">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-3 px-2 rounded-lg text-base font-medium transition-colors',
              isActive(item.href)
                ? 'text-coral bg-sand/40'
                : 'text-ink hover:bg-mist',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/contact#donate" class="btn-coral w-full">Donate</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
