---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<section class="relative bg-teal overflow-hidden">
  <!-- Soft brand color blobs for depth -->
  <div
    aria-hidden="true"
    class="absolute -top-24 -right-20 w-96 h-96 rounded-full bg-coral/20 blur-3xl"
  ></div>
  <div
    aria-hidden="true"
    class="absolute -bottom-32 -left-24 w-[30rem] h-[30rem] rounded-full bg-sand/15 blur-3xl"
  ></div>

  <!-- Subtle dot pattern -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.08]"
    style="background-image: radial-gradient(circle at 1px 1px, #FFF3B0 1px, transparent 0); background-size: 28px 28px;"
  ></div>

  <div class="relative container-page py-24 md:py-32 text-center">
    {eyebrow && (
      <p class="inline-flex items-center justify-center gap-3 mb-6 tracking-[0.25em] uppercase text-xs font-semibold text-coral">
        <span aria-hidden="true" class="block w-10 h-px bg-coral/70"></span>
        {eyebrow}
        <span aria-hidden="true" class="block w-10 h-px bg-coral/70"></span>
      </p>
    )}
    <h1 class="font-serif text-4xl md:text-6xl font-semibold text-sand leading-tight [text-shadow:0_2px_20px_rgba(0,0,0,0.2)]">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-6 text-lg md:text-xl text-white/90 max-w-2xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>

  <!-- Wave divider: soft S-curve transitions into the page content -->
  <svg
    aria-hidden="true"
    class="absolute bottom-0 left-0 w-full h-12 md:h-16 text-white"
    viewBox="0 0 1440 80"
    preserveAspectRatio="none"
  >
    <path
      d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
      fill="currentColor"
    />
  </svg>
</section>
