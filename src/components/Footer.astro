---
const year = new Date().getFullYear();
---

<footer class="relative bg-teal text-white overflow-hidden">
  <!-- Subtle brand accent stripe separating CTA band from footer body -->
  <div aria-hidden="true" class="h-px w-full bg-gradient-to-r from-transparent via-sand/40 to-transparent"></div>
  <div
    aria-hidden="true"
    class="absolute -top-20 -left-20 w-80 h-80 rounded-full bg-coral/10 blur-3xl pointer-events-none"
  ></div>
  <div class="relative container-page py-14 md:py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img
            src="/images/logo.png"
            alt="Lahsiv Foundation"
            class="h-12 w-auto bg-white rounded p-1"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <span
            class="hidden items-center justify-center h-12 w-12 rounded-lg bg-white text-teal font-serif font-semibold text-lg"
            aria-hidden="true"
          >L</span>
          <span class="font-serif text-xl font-semibold">Lahsiv Foundation</span>
        </div>
        <p class="text-white/80 text-sm leading-relaxed max-w-xs">
          Nurturing sports talent and promoting girl child education in the Andaman and Nicobar Islands.
        </p>
      </div>

      <div>
        <h3 class="text-white font-serif text-lg mb-4">Visit us</h3>
        <address class="not-italic text-white/85 text-sm leading-relaxed">
          No. 3, 1st Floor, Block-B,<br />
          Harmony Complex, M.G. Road,<br />
          Junglighat, Port Blair – 744103,<br />
          A&amp;N Islands.
        </address>
      </div>

      <div>
        <h3 class="text-white font-serif text-lg mb-4">Get in touch</h3>
        <ul class="text-white/85 text-sm space-y-2">
          <li>
            <a href="mailto:lahsivfoundation@gmail.com" class="hover:text-coral">
              lahsivfoundation@gmail.com
            </a>
          </li>
          <li>
            <a href="tel:+919963077855" class="hover:text-coral">
              +91 99630 77855
            </a>
          </li>
          <li class="pt-2">
            <a href="/contact" class="underline underline-offset-4 hover:text-coral">
              Contact &amp; donate →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-white/15 flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-xs text-white/70">
      <p>© {year} Lahsiv Foundation. All rights reserved.</p>
      <p>Registered NGO, Andaman and Nicobar Islands</p>
    </div>
  </div>
</footer>
