---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await event.render();

const photos =
  event.data.photos?.map((filename, i) => ({
    src: url(`/images/gallery/${event.slug}/${filename}`),
    alt: `${event.data.title} — photo ${i + 1}`,
  })) ?? [];

const formattedDate = (() => {
  try {
    const d = new Date(event.data.date);
    if (isNaN(d.getTime())) return event.data.date;
    return d.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return event.data.date;
  }
})();
---

<BaseLayout
  title={event.data.title}
  description={event.data.description}
  activeRoute="/gallery"
  ogImage={event.data.cover}
>
  <!-- CINEMATIC COVER HERO -->
  <section class="relative overflow-hidden bg-teal">
    <div class="absolute inset-0">
      <img
        src={url(event.data.cover)}
        alt={`${event.data.title} cover`}
        class="w-full h-full object-cover"
        onerror="this.style.display='none';"
      />
      <div
        aria-hidden="true"
        class="absolute inset-0"
        style="background: linear-gradient(to top, rgba(15,76,92,0.92) 0%, rgba(15,76,92,0.60) 40%, rgba(15,76,92,0.40) 70%, rgba(15,76,92,0.75) 100%);"
      ></div>
    </div>

    <!-- Color blobs for depth -->
    <div
      aria-hidden="true"
      class="absolute -top-24 -right-20 w-[28rem] h-[28rem] rounded-full bg-coral/20 blur-3xl mix-blend-soft-light pointer-events-none"
    ></div>

    <div class="relative container-page py-24 md:py-36">
      <a
        href={url('/gallery')}
        class="inline-flex items-center gap-2 text-sand/90 text-sm hover:text-sand transition-colors mb-10 group"
      >
        <span aria-hidden="true" class="transition-transform duration-300 group-hover:-translate-x-1">←</span>
        <span class="border-b border-sand/40 pb-0.5">Back to gallery</span>
      </a>

      <div class="max-w-3xl">
        <p class="text-coral text-xs font-semibold tracking-[0.28em] uppercase flex items-center gap-3 mb-5">
          <span aria-hidden="true" class="block w-8 h-px bg-coral"></span>
          Event Album
        </p>
        <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-semibold text-sand leading-[1.05] [text-shadow:0_2px_20px_rgba(0,0,0,0.35)]">
          {event.data.title}
        </h1>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sand/85 text-sm">
          <span class="tracking-wide">{formattedDate}</span>
          <span aria-hidden="true" class="block w-1 h-1 rounded-full bg-coral"></span>
          <span>{photos.length} {photos.length === 1 ? 'photo' : 'photos'}</span>
        </div>
        <p class="mt-6 text-body-lg text-sand/90 leading-relaxed [text-shadow:0_1px_8px_rgba(0,0,0,0.3)] max-w-2xl">
          {event.data.description}
        </p>
      </div>
    </div>

    <!-- Wave divider -->
    <svg
      aria-hidden="true"
      class="absolute bottom-0 left-0 w-full h-12 md:h-16 text-mist"
      viewBox="0 0 1440 80"
      preserveAspectRatio="none"
    >
      <path
        d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
        fill="currentColor"
      />
    </svg>
  </section>

  {Content && (
    <section class="pt-12 md:pt-16">
      <div class="container-page max-w-3xl prose prose-lg text-ink/85 leading-relaxed">
        <Content />
      </div>
    </section>
  )}

  <!-- PHOTO GRID -->
  <section class="section-padding">
    <div class="container-page">
      {photos.length === 0 ? (
        <div class="text-center py-16">
          <p class="font-serif text-2xl text-teal italic">Photos coming soon.</p>
          <p class="mt-3 text-stone">Check back when the album is published.</p>
        </div>
      ) : (
        <>
          <div class="flex items-end justify-between gap-4 mb-8 md:mb-10">
            <div>
              <p class="text-coral text-xs font-semibold tracking-[0.28em] uppercase flex items-center gap-3">
                <span aria-hidden="true" class="block w-6 h-px bg-coral"></span>
                Photos
              </p>
              <h2 class="mt-4 font-serif text-2xl md:text-3xl text-teal">
                The full album
              </h2>
            </div>
            <p class="hidden md:block text-sm text-stone italic">Click any photo to open the viewer</p>
          </div>
          <PhotoGrid images={photos} />
        </>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-teal text-white overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute -top-24 -right-20 w-[28rem] h-[28rem] rounded-full bg-coral/20 blur-3xl pointer-events-none"
    ></div>
    <div
      aria-hidden="true"
      class="absolute -bottom-24 -left-20 w-[30rem] h-[30rem] rounded-full bg-sand/15 blur-3xl pointer-events-none"
    ></div>
    <div
      aria-hidden="true"
      class="absolute inset-0 opacity-[0.08] pointer-events-none"
      style="background-image: radial-gradient(circle at 1px 1px, #FFF3B0 1px, transparent 0); background-size: 28px 28px;"
    ></div>

    <div class="relative container-page py-20 md:py-24">
      <div class="grid grid-cols-12 gap-8 items-center">
        <div class="col-span-12 md:col-span-8">
          <div aria-hidden="true" class="mb-6 flex items-center gap-3">
            <span class="block h-px w-10 bg-coral"></span>
            <span class="text-coral text-xs font-semibold tracking-[0.25em] uppercase">Keep exploring</span>
          </div>
          <h2 class="font-serif text-3xl md:text-5xl text-sand leading-[1.1]">
            More moments, more <span class="italic">stories</span>.
          </h2>
          <p class="mt-5 text-white/85 text-lg md:text-xl max-w-xl leading-relaxed">
            Browse the full archive or read how these moments become lasting impact.
          </p>
        </div>
        <div class="col-span-12 md:col-span-4 md:justify-self-end flex flex-col sm:flex-row gap-3">
          <a href={url('/gallery')} class="btn-coral text-base px-7 py-4 whitespace-nowrap shadow-lg shadow-black/20">
            All albums
          </a>
          <a href={url('/impact-stories')} class="btn border-2 border-sand/80 text-sand hover:bg-sand hover:text-teal hover:-translate-y-0.5 px-7 py-4 whitespace-nowrap">
            Impact stories
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
