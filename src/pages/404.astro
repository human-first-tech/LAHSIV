---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist." activeRoute="/">
  <section class="section-padding">
    <div class="container-page text-center max-w-xl">
      <p class="eyebrow mb-4">404</p>
      <h1 class="font-serif text-4xl md:text-6xl text-teal">Page not found</h1>
      <p class="mt-6 text-body-lg text-ink/80 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/contact" class="btn-secondary">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
